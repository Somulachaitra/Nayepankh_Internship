{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "nayepankhinternship",
  "compatibility_date": "2026-06-15",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./public", 
    "binding": "ASSETS"
  },
  "vars": {
    "GEMINI_API_KEY": ""
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
